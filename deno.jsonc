{
  "name": "@ggpwnkthx/opencode-scaffold",
  "version": "0.2.14",
  "description": "A simple scaffold for projects built with OpenCode.",
  "exports": "./src/main.ts",
  "imports": {
    "@scaffold/types": "./src/domain/types.ts"
  },
  "exclude": [
    ".*"
  ],
  "fmt": {
    "lineWidth": 88,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "trailingCommas": "onlyMultiLine",
    "operatorPosition": "nextLine"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "tasks": {
    "dev": "deno run --allow-read --allow-write ./src/main.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint ./src ./tests --fix",
    "lint:check": "deno lint ./src ./tests",
    "check": "deno check ./src ./tests",
    "test": "deno test --allow-read --allow-write --coverage=coverage",
    "build": "deno compile --allow-read --allow-write --output=dist/scaffold ./src/main.ts",
    "ci": "deno task fmt && deno task lint:check && deno task check && deno task test"
  }
}
